{
  "name": "character-generator",
  "version": "2.0.0",
  "private": true,
  "description": "Character Generator - Modern web application for generating RPG characters",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @char-gen/web dev",
    "dev:web:lan": "pnpm --filter @char-gen/web dev --host 0.0.0.0 --port 3000",
    "build": "turbo run build",
    "build:web": "pnpm build:shared && pnpm --filter @char-gen/web build",
    "build:shared": "pnpm --filter @char-gen/shared build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.13.0",
    "prettier": "^3.2.5",
    "turbo": "^2.3.0",
    "typescript-eslint": "^8.18.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
