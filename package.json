{
  "name": "character-generator",
  "version": "2.0.0",
  "private": true,
  "description": "Character Generator - Modern web/mobile UI for RPBotGenerator",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @char-gen/web dev",
    "dev:mobile": "pnpm --filter @char-gen/mobile start",
    "build": "turbo run build",
    "build:web": "pnpm --filter @char-gen/web build",
    "build:shared": "pnpm --filter @char-gen/shared build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "api": "cd packages/core && python -m bpui.api.main",
    "tauri:dev": "pnpm --filter @char-gen/desktop tauri dev",
    "tauri:build": "pnpm --filter @char-gen/desktop tauri build"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
