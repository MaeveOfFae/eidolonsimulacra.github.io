# API Keys Configuration
# Copy this file to .bpui.toml and fill in your values

# Engine: "openai", "google", "openai_compatible", or "auto"
engine = "openai_compatible"

# Engine Mode: "auto" or "explicit"
engine_mode = "auto"

# Model to use (provider-prefixed for openai_compatible)
model = "openrouter/openai/gpt-4o-mini"

# Generation settings
temperature = 0.7
max_tokens = 4096

# Batch processing
[batch]
max_concurrent = 3
rate_limit_delay = 1.0

# API Keys (choose your provider)
[api_keys]
# openai = "sk-..."
# google = "..."
# openrouter = "sk-or-..."
# deepseek = "..."
