{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Character Generator",
  "version": "2.0.0",
  "identifier": "com.chargen.app",
  "build": {
    "beforeBuildCommand": "pnpm --filter @char-gen/web build",
    "beforeDevCommand": "pnpm --filter @char-gen/web dev --host 127.0.0.1 --port 3000",
    "frontendDist": "../../web/dist",
    "devUrl": "http://127.0.0.1:3000"
  },
  "app": {
    "windows": [
      {
        "title": "Character Generator",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {}
}
